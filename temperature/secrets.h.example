// secrets.h.example
// Copy this file to "secrets.h" in the SAME folder and fill in real values.
// secrets.h is gitignored — it will never be committed.

#pragma once

// DEVICE CONFIG — which physical ESP32 this binary belongs to
#define DEVICE_ID "esp32_01"

// WIFI CONFIG
#define WIFI_SSID "your_wifi_ssid"
#define WIFI_PWD  "your_wifi_password"

// MQTT CONFIG
#define MQTT_SERVER   "your.cluster.s1.eu.hivemq.cloud"
#define MQTT_PORT     8883
#define MQTT_USERNAME "your_mqtt_username"
#define MQTT_PASSWORD "your_mqtt_password"
