// secrets.h.example
// Copy this file to "secrets.h" in the SAME folder and fill in real values.
// secrets.h is gitignored — it will never be committed.
//
// IMPORTANT for base.ino: this file is flashed manually per device.
// Set DEVICE_ID to esp32_01 / esp32_02 / esp32_03 etc. BEFORE each flash.
//
// NOTE: WiFi and MQTT credentials are NOT stored here.
// On first boot (or after holding the BOOT button on power-up), the device
// opens its own WiFi AP named "ESP32-Setup-<DEVICE_ID>". Connect to it from
// your phone/laptop and a setup page pops up with fields for:
//   - WiFi SSID / password
//   - MQTT server / port / username / password
// All of it gets saved on-device (NVS flash), not in this file.

#pragma once

// DEVICE CONFIG — unique per physical ESP32
#define DEVICE_ID "esp32_01"
